{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Auth failures / minute",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (method, reason) (rate(auth_failures_total[1m])) * 60",
          "legendFormat": "{{method}} / {{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "Auth success rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (method) (rate(auth_success_total[1m])) / (sum by (method) (rate(auth_success_total[1m])) + sum by (method) (rate(auth_failures_total[1m])))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by status",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[1m]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Request latency p95 (s)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["gateway", "auth"],
  "time": {"from": "now-15m", "to": "now"},
  "timezone": "browser",
  "title": "Secure API Gateway",
  "uid": "gateway-auth",
  "version": 1
}
