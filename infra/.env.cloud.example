# Copy file nay thanh '.env' (CUNG thu muc infra/) roi sua gia tri, sau do chay:
#   docker compose -f docker-compose.cloud.yml up -d --build
#
# LUU Y: KHONG commit file .env that (da co trong .gitignore neu can them).

# Domain DuckDNS da tro ve IP cong khai cua VM Oracle (vd: nt219-gw.duckdns.org)
GATEWAY_DOMAIN=YOURNAME.duckdns.org

# Email nhan canh bao het han cert Let's Encrypt (de trong cung duoc)
ACME_EMAIL=you@example.com
